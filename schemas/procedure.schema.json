{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lexstab.invalid/schemas/procedure.schema.json",
  "$defs": {
    "ProcedureEvaluationContract": {
      "additionalProperties": false,
      "properties": {
        "registered_checks": {
          "items": {
            "type": "string"
          },
          "title": "Registered Checks",
          "type": "array"
        },
        "forbidden_operation_ids": {
          "items": {
            "type": "string"
          },
          "title": "Forbidden Operation Ids",
          "type": "array"
        },
        "required_observable_events": {
          "items": {
            "type": "string"
          },
          "title": "Required Observable Events",
          "type": "array"
        }
      },
      "title": "ProcedureEvaluationContract",
      "type": "object"
    },
    "ProcedureStep": {
      "additionalProperties": false,
      "properties": {
        "step_id": {
          "pattern": "^[A-Z][A-Z0-9_]+$",
          "title": "Step Id",
          "type": "string"
        },
        "instruction": {
          "minLength": 1,
          "title": "Instruction",
          "type": "string"
        }
      },
      "required": [
        "step_id",
        "instruction"
      ],
      "title": "ProcedureStep",
      "type": "object"
    },
    "RenderingValidation": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "$ref": "#/$defs/ValidationStatus"
        },
        "reviewed_by": {
          "items": {
            "type": "string"
          },
          "title": "Reviewed By",
          "type": "array"
        },
        "approved_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Approved At"
        }
      },
      "required": [
        "status"
      ],
      "title": "RenderingValidation",
      "type": "object"
    },
    "ValidationStatus": {
      "enum": [
        "CANDIDATE",
        "NEEDS_REVIEW",
        "APPROVED",
        "FROZEN",
        "REJECTED",
        "SUPERSEDED"
      ],
      "title": "ValidationStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "1.2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "procedure_id": {
      "pattern": "^SKILL_[A-Z0-9_]+$",
      "title": "Procedure Id",
      "type": "string"
    },
    "procedure_version": {
      "title": "Procedure Version",
      "type": "string"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "applies_to_operation_ids": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Applies To Operation Ids",
      "type": "array"
    },
    "required_inputs": {
      "items": {
        "type": "string"
      },
      "title": "Required Inputs",
      "type": "array"
    },
    "steps": {
      "items": {
        "$ref": "#/$defs/ProcedureStep"
      },
      "minItems": 1,
      "title": "Steps",
      "type": "array"
    },
    "forbidden_behaviors": {
      "items": {
        "type": "string"
      },
      "title": "Forbidden Behaviors",
      "type": "array"
    },
    "evaluation_contract": {
      "$ref": "#/$defs/ProcedureEvaluationContract"
    },
    "output_contract": {
      "title": "Output Contract",
      "type": "string"
    },
    "validation": {
      "$ref": "#/$defs/RenderingValidation"
    },
    "provenance": {
      "additionalProperties": true,
      "title": "Provenance",
      "type": "object"
    }
  },
  "required": [
    "procedure_id",
    "procedure_version",
    "title",
    "applies_to_operation_ids",
    "required_inputs",
    "steps",
    "evaluation_contract",
    "output_contract",
    "validation",
    "provenance"
  ],
  "title": "Procedure",
  "type": "object"
}
