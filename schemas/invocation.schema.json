{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lexstab.invalid/schemas/invocation.schema.json",
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "cell_id": {
      "title": "Cell Id",
      "type": "string"
    },
    "role": {
      "title": "Role",
      "type": "string"
    },
    "provider": {
      "title": "Provider",
      "type": "string"
    },
    "requested_model_id": {
      "title": "Requested Model Id",
      "type": "string"
    },
    "reported_model_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reported Model Id"
    },
    "fingerprint": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fingerprint"
    },
    "timestamp": {
      "title": "Timestamp",
      "type": "string"
    },
    "messages": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Messages",
      "type": "array"
    },
    "tools": {
      "anyOf": [
        {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tools"
    },
    "response_schema_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Response Schema Id"
    },
    "requested_parameters": {
      "additionalProperties": true,
      "title": "Requested Parameters",
      "type": "object"
    },
    "accepted_parameters": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Accepted Parameters"
    },
    "raw_response": {
      "title": "Raw Response"
    },
    "normalized_text": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Normalized Text"
    },
    "tool_calls": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Tool Calls",
      "type": "array"
    },
    "tool_call_mode": {
      "anyOf": [
        {
          "enum": [
            "native",
            "fallback_json",
            "mock"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tool Call Mode"
    },
    "usage": {
      "additionalProperties": true,
      "title": "Usage",
      "type": "object"
    },
    "latency_ms": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Latency Ms"
    },
    "cost_estimate": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cost Estimate"
    },
    "finish_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Finish Reason"
    },
    "provider_request_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider Request Id"
    },
    "transport_retries": {
      "default": 0,
      "title": "Transport Retries",
      "type": "integer"
    },
    "parse_status": {
      "default": "ok",
      "enum": [
        "ok",
        "error",
        "empty"
      ],
      "title": "Parse Status",
      "type": "string"
    },
    "parse_error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parse Error"
    },
    "content_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Content Hash"
    },
    "cached": {
      "default": false,
      "title": "Cached",
      "type": "boolean"
    }
  },
  "required": [
    "run_id",
    "cell_id",
    "role",
    "provider",
    "requested_model_id",
    "timestamp",
    "messages",
    "requested_parameters",
    "raw_response"
  ],
  "title": "InvocationRecord",
  "type": "object"
}
