{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lexstab.invalid/schemas/operation.schema.json",
  "$defs": {
    "ArgumentPreservation": {
      "enum": [
        "VERBATIM",
        "CANONICAL",
        "SEMANTIC"
      ],
      "title": "ArgumentPreservation",
      "type": "string"
    },
    "ArgumentSpec": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": [
            "string",
            "integer",
            "number",
            "boolean",
            "array",
            "object"
          ],
          "title": "Type",
          "type": "string"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "pattern": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pattern"
        },
        "minimum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum"
        },
        "maximum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum"
        },
        "enum": {
          "anyOf": [
            {
              "items": {},
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Enum"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "preservation": {
          "$ref": "#/$defs/ArgumentPreservation",
          "default": "SEMANTIC"
        }
      },
      "required": [
        "type",
        "required"
      ],
      "title": "ArgumentSpec",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "1.2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "operation_id": {
      "pattern": "^[A-Z][A-Z0-9_]+$",
      "title": "Operation Id",
      "type": "string"
    },
    "display_name": {
      "minLength": 1,
      "title": "Display Name",
      "type": "string"
    },
    "entity_type": {
      "pattern": "^[A-Z][A-Z0-9_]+$",
      "title": "Entity Type",
      "type": "string"
    },
    "tool": {
      "pattern": "^[a-z][a-z0-9_]+$",
      "title": "Tool",
      "type": "string"
    },
    "arguments": {
      "additionalProperties": {
        "$ref": "#/$defs/ArgumentSpec"
      },
      "title": "Arguments",
      "type": "object"
    },
    "preconditions": {
      "items": {
        "type": "string"
      },
      "title": "Preconditions",
      "type": "array"
    },
    "effects": {
      "items": {
        "type": "string"
      },
      "title": "Effects",
      "type": "array"
    },
    "invalid_when": {
      "items": {
        "type": "string"
      },
      "title": "Invalid When",
      "type": "array"
    },
    "primary_contrast": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Primary Contrast"
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    }
  },
  "required": [
    "operation_id",
    "display_name",
    "entity_type",
    "tool",
    "arguments",
    "preconditions",
    "effects"
  ],
  "title": "Operation",
  "type": "object"
}
