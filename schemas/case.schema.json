{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lexstab.invalid/schemas/case.schema.json",
  "$defs": {
    "CanonicalIntent": {
      "additionalProperties": false,
      "properties": {
        "entity_type": {
          "enum": [
            "ACCOUNT",
            "APPROVAL_REQUEST",
            "CUSTOMER",
            "INCIDENT",
            "ORDER"
          ],
          "title": "Entity Type",
          "type": "string"
        },
        "entity_id": {
          "title": "Entity Id",
          "type": "string"
        },
        "operation_id": {
          "enum": [
            "CLOSE_INCIDENT",
            "ESCALATE_INCIDENT",
            "REASSIGN_INCIDENT",
            "REFUND_DUPLICATE_CHARGE",
            "REQUEST_APPROVAL",
            "REQUEST_MANAGER_REVIEW",
            "REQUEST_MORE_INFORMATION",
            "SUSPEND_ACCOUNT"
          ],
          "title": "Operation Id",
          "type": "string"
        },
        "arguments": {
          "additionalProperties": true,
          "title": "Arguments",
          "type": "object"
        }
      },
      "required": [
        "entity_type",
        "entity_id",
        "operation_id",
        "arguments"
      ],
      "title": "CanonicalIntent",
      "type": "object"
    },
    "GoldDecision": {
      "enum": [
        "ACT",
        "CLARIFY",
        "REFUSE"
      ],
      "title": "GoldDecision",
      "type": "string"
    },
    "GoldSpec": {
      "additionalProperties": false,
      "properties": {
        "decision": {
          "$ref": "#/$defs/GoldDecision"
        },
        "tool": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool"
        },
        "arguments": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Arguments"
        },
        "resulting_state": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resulting State"
        },
        "refusal_reason_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Refusal Reason Code"
        },
        "refusal_policy_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Refusal Policy Id"
        },
        "clarification_targets": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Clarification Targets"
        }
      },
      "required": [
        "decision"
      ],
      "title": "GoldSpec",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "1.2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "case_id": {
      "pattern": "^[A-Z][A-Z0-9_]+$",
      "title": "Case Id",
      "type": "string"
    },
    "domain": {
      "title": "Domain",
      "type": "string"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "family_id": {
      "pattern": "^[A-Z][A-Z0-9_]+$",
      "title": "Family Id",
      "type": "string"
    },
    "canonical": {
      "$ref": "#/$defs/CanonicalIntent"
    },
    "initial_state": {
      "additionalProperties": true,
      "title": "Initial State",
      "type": "object"
    },
    "gold": {
      "$ref": "#/$defs/GoldSpec"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "difficulty": {
      "enum": [
        "basic",
        "intermediate",
        "advanced"
      ],
      "title": "Difficulty",
      "type": "string"
    },
    "created_by": {
      "title": "Created By",
      "type": "string"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    }
  },
  "required": [
    "case_id",
    "domain",
    "title",
    "family_id",
    "canonical",
    "initial_state",
    "gold",
    "tags",
    "difficulty",
    "created_by",
    "created_at"
  ],
  "title": "CanonicalCase",
  "type": "object"
}
